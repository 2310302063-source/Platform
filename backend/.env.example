# Firebase Configuration
FIREBASE_PROJECT_ID=ndidi-8d9fc
FIREBASE_AUTH_DOMAIN=ndidi-8d9fc.firebaseapp.com
FIREBASE_DATABASE_URL=https://ndidi-8d9fc-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=ndidi-8d9fc.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=327533481489
FIREBASE_APP_ID=1:327533481489:web:800aed03a5086f1720abb0

# Service Account (Download from Firebase Console: Project Settings > Service Accounts)
# Option 1: Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option 2: Service account as environment variable (base64 encoded)
# FIREBASE_SERVICE_ACCOUNT_JSON=your_base64_encoded_json_here

# Backend Server
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Session Configuration
SESSION_SECRET=your_very_secure_random_string_here_change_me

# Payment Gateway Keys
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

OPAY_API_KEY=your_opay_api_key_here
OPAY_SECRET_KEY=your_opay_secret_key_here

PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Cryptocurrency (Optional)
CRYPTO_API_KEY=your_crypto_api_key_here
CRYPTO_ENABLED=true

# AI Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_MONITORING_ENABLED=true
AI_SENSITIVITY=5

# Email Configuration (For notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@platform.com

# Encryption
ENCRYPTION_ENABLED=true
E2E_PROTOCOL=TLS_1_3

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# Analytics
ANALYTICS_ENABLED=true
