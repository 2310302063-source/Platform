{
  "name": "social-learning-platform",
  "version": "1.0.0",
  "description": "Enterprise-grade Social Learning & Quiz Platform with E2E Encryption and AI Governance",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "ts-node --esm --transpile-only backend/server.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "tsc --project backend/tsconfig.json",
    "start": "node backend/server.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.tsx,.js",
    "type-check": "tsc --noEmit",
    "firebase:login": "firebase login",
    "firebase:init": "firebase init",
    "firebase:deploy": "firebase deploy",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules,database",
    "firebase:deploy:storage": "firebase deploy --only storage",
    "init:firestore": "ts-node backend/init-firestore.ts",
    "setup:firebase": "npm install -g firebase-tools && firebase login && firebase use ndidi-8d9fc && npm run firebase:deploy:rules && npm run init:firestore",
    "railway:build": "npm install && npm run build:backend",
    "postinstall": ""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.28.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dexie": "^3.2.4",
    "dompurify": "^3.0.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase": "^10.7.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "lucide-react": "^0.318.0",
    "peerjs": "^1.4.7",
    "pg": "^8.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "redis": "^4.6.0",
    "socket.io-client": "^4.7.0",
    "sodium-plus": "^0.8.0",
    "stripe": "^14.8.0",
    "tailwindcss": "^3.3.0",
    "tweetnacl": "^1.0.3",
    "webrtc-adapter": "^8.2.1",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@esbuild/win32-x64": "^0.27.4",
    "@testing-library/react": "^14.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.56.0",
    "eslint-config-react-app": "^7.0.0",
    "firebase-tools": "^13.0.0",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
